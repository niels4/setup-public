source "${ZDOTDIR}/includes/zsh-base.sh"
source "${ZDOTDIR}/includes/completions.sh"

# ** drop in configs ** #
for file in ${ZDOTDIR}/zshrc.d/*.sh; do
  source "$file"
done

source "${ZDOTDIR}/includes/plugins.sh"
source "${ZDOTDIR}/includes/tools.sh"

# ** aliases ** #

# reload all zsh instances with rzsh
alias rzsh="killall -USR1 zsh || true; killall -USR1 -- -zsh || true"

# dev setup functions
alias setup="~/s/setup.sh"
alias webdev="~/s/webdev"
alias shelldev="~/s/shelldev"

# install all default globals for current version of node
alias npm-globals='xargs npm install -g < "${MISE_NODE_DEFAULT_PACKAGES_FILE}"'

# quickly edit zshrc file
alias ezsh="nvim $ZDOTDIR/.zshrc"

# functions for working with github gists
alias print-gist="~/s/print-gist.sh"
alias eval-gist="bash -c \"\$(~/s/print-gist.sh)\""

# show colors every time we use ls
alias ls='ls --color=auto'
alias l='ls -lah'

# test our ssh authorization with github
alias github-test-ssh='ssh -T git@github.com'

# compinit loads cached completions, use this alias when adding or updating completions
alias refresh-completions-cache='rm -f ${ZDOTDIR}/.zcompdump && exec zsh'

# ** keybindings ** #
bindkey -v
bindkey '^p' history-search-backward
bindkey '^n' history-search-forward
bindkey '^[[Z' reverse-menu-complete
bindkey '^y' autosuggest-accept

